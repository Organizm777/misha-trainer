{
  "ci": {
    "collect": {
      "staticDistDir": "./",
      "url": [
        "http://localhost/index.html?choose",
        "http://localhost/grade3_v2.html",
        "http://localhost/grade10_v2.html"
      ],
      "numberOfRuns": 2,
      "settings": {
        "chromeFlags": "--headless=new --no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "includePassedAssertions": true,
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.7}],
        "categories:accessibility": ["error", {"minScore": 0.9}],
        "categories:best-practices": ["warn", {"minScore": 0.85}],
        "categories:seo": ["warn", {"minScore": 0.85}],
        "errors-in-console": ["error", {"minScore": 1}],
        "total-byte-weight": ["error", {"maxNumericValue": 1800000, "aggregationMethod": "pessimistic"}],
        "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.45, "aggregationMethod": "pessimistic"}],
        "largest-contentful-paint": ["warn", {"maxNumericValue": 5000, "aggregationMethod": "pessimistic"}]
      }
    }
  }
}
