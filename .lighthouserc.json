{
  "ci": {
    "collect": {
      "startServerCommand": "npx --yes http-server . -p 4173 -c-1 --silent",
      "startServerReadyPattern": "Available on",
      "url": [
        "http://127.0.0.1:4173/index.html?choose",
        "http://127.0.0.1:4173/grade3_v2.html",
        "http://127.0.0.1:4173/grade10_v2.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.7}],
        "categories:accessibility": ["error", {"minScore": 0.9}],
        "categories:best-practices": ["warn", {"minScore": 0.85}],
        "categories:seo": ["warn", {"minScore": 0.85}],
        "total-byte-weight": ["warn", {"maxNumericValue": 1700000}],
        "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.12}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
